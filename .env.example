# Copy to .env for local development. NEVER commit .env to git.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Gmail OAuth2
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_TOKEN_PATH=./token.json

# Mercado Pago
MP_ACCESS_TOKEN=your-mp-access-token

# App
APP_ENV=development
LOG_LEVEL=DEBUG
ALLOWED_ORIGINS=["http://localhost:8501"]

# Encryption (AES-256-GCM)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=your-64-char-hex-key-here
# Optional: set during key rotation, then promote to ENCRYPTION_KEY when done
# ENCRYPTION_KEY_V2=your-new-64-char-hex-key

# Ingestion (used by pipeline.py)
FINANCE_USER_ID=your-supabase-user-uuid
